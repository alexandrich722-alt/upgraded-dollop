import { useState, useMemo, useRef, useEffect } from 'react';
import { GitBranch, ZoomIn, ZoomOut, Maximize2 } from 'lucide-react';
import { useStore } from '../store';
import { Card, SectionHeader, Badge, EmptyState } from '../components/ui';
import type { Goal, Project, Task, Habit } from '../types';

interface GraphNode {
  id: string;
  label: string;
  type: 'goal' | 'project' | 'task' | 'habit';
  x: number;
  y: number;
  vx: number;
  vy: number;
  r: number;
  color: string;
  data: any;
}

interface GraphEdge { source: string; target: string }

const typeColors: Record<string, string> = {
  goal: '#a78bfa', project: '#60a5fa', task: '#22d3ee', habit: '#34d399',
};
const typeGlow: Record<string, string> = {
  goal: 'rgba(167,139,250,0.3)', project: 'rgba(96,165,250,0.3)', task: 'rgba(34,211,238,0.3)', habit: 'rgba(52,211,153,0.3)',
};

export default function LifeGraph() {
  const { state } = useStore();
  const [filters, setFilters] = useState<Set<string>>(new Set(['goal', 'project', 'task', 'habit']));
  const [selected, setSelected] = useState<GraphNode | null>(null);
  const [zoom, setZoom] = useState(1);
  const [pan, setPan] = useState({ x: 0, y: 0 });
  const svgRef = useRef<SVGSVGElement>(null);
  const isDragging = useRef(false);
  const dragStart = useRef({ x: 0, y: 0, panX: 0, panY: 0 });

  const { nodes, edges } = useMemo(() => {
    const n: GraphNode[] = [];
    const e: GraphEdge[] = [];

    state.goals.filter(g => !g.archived).forEach((g: Goal) => {
      n.push({ id: g.id, label: g.title, type: 'goal', x: 0, y: 0, vx: 0, vy: 0, r: 28, color: typeColors.goal, data: g });
    });
    state.projects.filter(p => !p.archived).forEach((p: Project) => {
      n.push({ id: p.id, label: p.title, type: 'project', x: 0, y: 0, vx: 0, vy: 0, r: 22, color: typeColors.project, data: p });
      if (p.relatedGoals && p.relatedGoals.length > 0) p.relatedGoals.forEach(gid => e.push({ source: p.id, target: gid }));
    });
    state.tasks.filter(t => !t.archived).forEach((t: Task) => {
      n.push({ id: t.id, label: t.title, type: 'task', x: 0, y: 0, vx: 0, vy: 0, r: 16, color: typeColors.task, data: t });
      if (t.goalId) e.push({ source: t.id, target: t.goalId });
      if (t.projectId) e.push({ source: t.id, target: t.projectId });
    });
    state.habits.filter(h => !h.archived).forEach((h: Habit) => {
      n.push({ id: h.id, label: h.title, type: 'habit', x: 0, y: 0, vx: 0, vy: 0, r: 18, color: typeColors.habit, data: h });
      if (h.relatedGoalId) e.push({ source: h.id, target: h.relatedGoalId });
    });

    // Initialize positions in a circle
    const cx = 300, cy = 250;
    n.forEach((node, i) => {
      const angle = (i / n.length) * Math.PI * 2;
      const radius = 150 + (node.type === 'goal' ? 0 : node.type === 'project' ? 50 : 100);
      node.x = cx + Math.cos(angle) * radius;
      node.y = cy + Math.sin(angle) * radius;
    });

    return { nodes: n, edges: e };
  }, [state.goals, state.projects, state.tasks, state.habits]);

  // Force simulation
  const [positions, setPositions] = useState<GraphNode[]>(nodes);
  const animRef = useRef<number>(0);

  useEffect(() => {
    setPositions(nodes);
    let frame = 0;
    const maxFrames = 120;

    const simulate = () => {
      if (frame >= maxFrames) { cancelAnimationFrame(animRef.current); return; }
      frame++;
      const sim = [...positions];
      const k = 0.08;
      const repulsion = 8000;
      const attraction = 0.02;
      const centerForce = 0.001;

      // Repulsion (all nodes push apart)
      for (let i = 0; i < sim.length; i++) {
        for (let j = i + 1; j < sim.length; j++) {
          const dx = sim[i].x - sim[j].x;
          const dy = sim[i].y - sim[j].y;
          const dist = Math.max(1, Math.sqrt(dx * dx + dy * dy));
          const force = repulsion / (dist * dist);
          const fx = (dx / dist) * force;
          const fy = (dy / dist) * force;
          sim[i].vx += fx * k;
          sim[i].vy += fy * k;
          sim[j].vx -= fx * k;
          sim[j].vy -= fy * k;
        }
      }

      // Attraction (connected nodes pull together)
      edges.forEach(edge => {
        const s = sim.find(n => n.id === edge.source);
        const t = sim.find(n => n.id === edge.target);
        if (!s || !t) return;
        const dx = t.x - s.x;
        const dy = t.y - s.y;
        const dist = Math.max(1, Math.sqrt(dx * dx + dy * dy));
        const force = dist * attraction;
        s.vx += (dx / dist) * force * k;
        s.vy += (dy / dist) * force * k;
        t.vx -= (dx / dist) * force * k;
        t.vy -= (dy / dist) * force * k;
      });

      // Center gravity
      sim.forEach(node => {
        node.vx += (300 - node.x) * centerForce;
        node.vy += (250 - node.y) * centerForce;
        node.vx *= 0.85;
        node.vy *= 0.85;
        node.x += node.vx;
        node.y += node.vy;
      });

      setPositions([...sim]);
      animRef.current = requestAnimationFrame(simulate);
    };

    animRef.current = requestAnimationFrame(simulate);
    return () => cancelAnimationFrame(animRef.current);
  }, [nodes, edges]);

  const filteredNodes = positions.filter(n => filters.has(n.type));
  const filteredNodeIds = new Set(filteredNodes.map(n => n.id));
  const filteredEdges = edges.filter(e => filteredNodeIds.has(e.source) && filteredNodeIds.has(e.target));

  const unlinked = filteredNodes.filter(n => !filteredEdges.some(e => e.source === n.id || e.target === n.id));

  const handleMouseDown = (e: React.MouseEvent) => {
    isDragging.current = true;
    dragStart.current = { x: e.clientX, y: e.clientY, panX: pan.x, panY: pan.y };
  };
  const handleMouseMove = (e: React.MouseEvent) => {
    if (!isDragging.current) return;
    setPan({ x: dragStart.current.panX + (e.clientX - dragStart.current.x), y: dragStart.current.panY + (e.clientY - dragStart.current.y) });
  };
  const handleMouseUp = () => { isDragging.current = false; };

  const toggleFilter = (type: string) => {
    setFilters(prev => { const n = new Set(prev); n.has(type) ? n.delete(type) : n.add(type); return n; });
  };

  return (
    <div className="p-4 sm:p-6 max-w-7xl mx-auto animate-fade-in">
      <SectionHeader title="Life Graph" subtitle="Visualize how everything connects" />

      {filteredNodes.length === 0 ? (
        <EmptyState icon={<GitBranch className="w-8 h-8" />} title="No data to graph" description="Add goals, projects, tasks, or habits to see your life graph" />
      ) : (
        <div className="grid grid-cols-1 lg:grid-cols-4 gap-4">
          {/* Graph canvas */}
          <div className="lg:col-span-3">
            <Card className="p-0 overflow-hidden relative" gradient="gradient-mesh">
              {/* Controls */}
              <div className="absolute top-3 right-3 z-10 flex gap-1.5">
                <button onClick={() => setZoom(z => Math.min(2, z + 0.2))} className="p-2 rounded-lg glass hover:bg-nova-card-hover transition-colors" aria-label="Zoom in"><ZoomIn className="w-4 h-4 text-nova-dim" /></button>
                <button onClick={() => setZoom(z => Math.max(0.5, z - 0.2))} className="p-2 rounded-lg glass hover:bg-nova-card-hover transition-colors" aria-label="Zoom out"><ZoomOut className="w-4 h-4 text-nova-dim" /></button>
                <button onClick={() => { setZoom(1); setPan({ x: 0, y: 0 }); }} className="p-2 rounded-lg glass hover:bg-nova-card-hover transition-colors" aria-label="Reset view"><Maximize2 className="w-4 h-4 text-nova-dim" /></button>
              </div>

              {/* Filters */}
              <div className="absolute top-3 left-3 z-10 flex gap-1.5">
                {(['goal', 'project', 'task', 'habit'] as const).map(type => (
                  <button key={type} onClick={() => toggleFilter(type)} className={`badge cursor-pointer transition-all ${filters.has(type) ? 'border' : 'opacity-40'}`} style={filters.has(type) ? { background: `${typeColors[type]}20`, color: typeColors[type], borderColor: `${typeColors[type]}30` } : {}}>
                    {type.charAt(0).toUpperCase() + type.slice(1)}s
                  </button>
                ))}
              </div>

              <svg
                ref={svgRef}
                viewBox="0 0 600 500"
                className="w-full h-[500px] cursor-grab active:cursor-grabbing"
                onMouseDown={handleMouseDown}
                onMouseMove={handleMouseMove}
                onMouseUp={handleMouseUp}
                onMouseLeave={handleMouseUp}
                style={{ transform: `translate(${pan.x}px, ${pan.y}px) scale(${zoom})`, transformOrigin: 'center' }}
              >
                {/* Edges */}
                <g>
                  {filteredEdges.map((edge, i) => {
                    const s = filteredNodes.find(n => n.id === edge.source);
                    const t = filteredNodes.find(n => n.id === edge.target);
                    if (!s || !t) return null;
                    return (
                      <line
                        key={i}
                        x1={s.x} y1={s.y} x2={t.x} y2={t.y}
                        stroke="#2a2a4a" strokeWidth="1.5" strokeOpacity="0.5"
                        className="transition-all duration-300"
                      />
                    );
                  })}
                </g>

                {/* Nodes */}
                <g>
                  {filteredNodes.map(node => (
                    <g
                      key={node.id}
                      transform={`translate(${node.x}, ${node.y})`}
                      className="cursor-pointer"
                      onClick={() => setSelected(node)}
                    >
                      {/* Glow */}
                      <circle r={node.r + 4} fill={node.color} opacity="0.08" />
                      {/* Main circle */}
                      <circle
                        r={node.r}
                        fill={node.color}
                        fillOpacity="0.15"
                        stroke={node.color}
                        strokeWidth="2"
                        style={{ filter: `drop-shadow(0 0 6px ${typeGlow[node.type]})` }}
                        className="transition-all duration-200"
                      />
                      {/* Label */}
                      <text
                        textAnchor="middle"
                        dy="0.35em"
                        fill="#ececf5"
                        fontSize={node.type === 'goal' ? '11' : '9'}
                        fontWeight={node.type === 'goal' ? '600' : '400'}
                        className="pointer-events-none select-none"
                      >
                        {node.label.length > 18 ? node.label.slice(0, 16) + '…' : node.label}
                      </text>
                    </g>
                  ))}
                </g>
              </svg>

              {/* Stats bar */}
              <div className="absolute bottom-3 left-3 right-3 flex items-center justify-between text-xs text-nova-muted">
                <span>{filteredNodes.length} nodes · {filteredEdges.length} connections</span>
                {unlinked.length > 0 && <span className="text-accent-gold">{unlinked.length} unlinked</span>}
              </div>
            </Card>
          </div>

          {/* Side panel */}
          <div className="space-y-4">
            {selected ? (
              <Card className="p-4 animate-scale-in">
                <div className="flex items-center gap-2 mb-3">
                  <div className="w-8 h-8 rounded-lg flex items-center justify-center" style={{ background: `${selected.color}20`, border: `1px solid ${selected.color}30` }}>
                    <span className="text-xs font-bold" style={{ color: selected.color }}>{selected.type.charAt(0).toUpperCase()}</span>
                  </div>
                  <div>
                    <p className="text-xs text-nova-muted uppercase tracking-wider">{selected.type}</p>
                    <p className="text-sm font-medium text-nova-text truncate">{selected.label}</p>
                  </div>
                </div>
                {selected.type === 'goal' && (
                  <div className="space-y-2 text-xs">
                    <p className="text-nova-dim">{selected.data.description || 'No description'}</p>
                    <div className="flex items-center gap-2"><Badge color="violet">{selected.data.priority}</Badge><Badge color="emerald">{selected.data.progress}%</Badge></div>
                    <p className="text-nova-muted">Milestones: {selected.data.milestones.filter((m: any) => m.done).length}/{selected.data.milestones.length}</p>
                  </div>
                )}
                {selected.type === 'project' && (
                  <div className="space-y-2 text-xs">
                    <p className="text-nova-dim">{selected.data.description || 'No description'}</p>
                    <div className="flex items-center gap-2"><Badge color="blue">{selected.data.status}</Badge><Badge color="cyan">{selected.data.progress}%</Badge></div>
                  </div>
                )}
                {selected.type === 'task' && (
                  <div className="space-y-2 text-xs">
                    <div className="flex items-center gap-2"><Badge color={selected.data.priority === 'critical' ? 'rose' : selected.data.priority === 'high' ? 'gold' : 'cyan'}>{selected.data.priority}</Badge><Badge color="muted">{selected.data.status}</Badge></div>
                    {selected.data.estimatedMinutes > 0 && <p className="text-nova-muted">Est: {selected.data.estimatedMinutes}m</p>}
                  </div>
                )}
                {selected.type === 'habit' && (
                  <div className="space-y-2 text-xs">
                    <div className="flex items-center gap-2"><Badge color="emerald">{selected.data.streak} day streak</Badge><Badge color="muted">{selected.data.completionRate}%</Badge></div>
                    <p className="text-nova-muted">Best: {selected.data.bestStreak} days</p>
                  </div>
                )}
                <button onClick={() => setSelected(null)} className="btn-ghost w-full mt-3 text-xs">Close</button>
              </Card>
            ) : (
              <Card className="p-4">
                <p className="text-xs text-nova-muted uppercase tracking-wider mb-2">Graph Analysis</p>
                <p className="text-sm text-nova-dim mb-3">Click any node to see details.</p>
                {unlinked.length > 0 && (
                  <div>
                    <p className="text-xs text-accent-gold mb-2">{unlinked.length} unlinked nodes:</p>
                    <div className="space-y-1 max-h-48 overflow-y-auto no-scrollbar">
                      {unlinked.map(n => (
                        <button key={n.id} onClick={() => setSelected(n)} className="flex items-center gap-2 text-xs w-full text-left p-1.5 rounded-lg hover:bg-nova-surface transition-colors">
                          <span className="w-2 h-2 rounded-full shrink-0" style={{ background: n.color }} />
                          <span className="text-nova-dim truncate">{n.label}</span>
                        </button>
                      ))}
                    </div>
                  </div>
                )}
                {unlinked.length === 0 && <p className="text-xs text-accent-emerald">All nodes are connected. Healthy graph!</p>}
              </Card>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
